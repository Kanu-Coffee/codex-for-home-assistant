#!/command/with-contenv bashio
# shellcheck shell=bash
set -Eeuo pipefail

exit_code=${1:-1}
if [[ "${exit_code}" -ne 0 && "${exit_code}" -ne 256 ]]; then
  bashio::log.error "sshd stopped unexpectedly with exit code ${exit_code}; web terminal remains available"
else
  bashio::log.warning 'sshd stopped; S6 will restart it'
fi
