#!/command/with-contenv bashio
# shellcheck shell=bash
set -Eeuo pipefail

umask 077

readonly RUNTIME_DIR=/run/codex-ha
readonly DATA_HOME=/data/home
readonly CODEX_DATA=/data/codex
readonly SSH_DATA=/data/ssh
readonly TMUX_DATA=/data/tmux
readonly DEFAULT_AGENTS=/usr/local/share/codex-ha/AGENTS.md
readonly CODEX_AGENTS=${CODEX_DATA}/AGENTS.md
readonly CODEX_AGENTS_OVERRIDE=${CODEX_DATA}/AGENTS.override.md
readonly LEGACY_PLAYWRIGHT_SECRETS=${RUNTIME_DIR}/playwright-secrets.env
readonly PLAYWRIGHT_OUTPUT=${RUNTIME_DIR}/playwright-output
readonly HA_RENDER_UPSTREAM=${RUNTIME_DIR}/home-assistant-render-upstream.conf
readonly HA_BROWSER_TOKEN_FILE=${RUNTIME_DIR}/home-assistant-browser.token
readonly HA_BROWSER_AUTH_STATUS=${RUNTIME_DIR}/browser-auth-status.json
readonly HA_BROWSER_NETWORK_STATUS=${RUNTIME_DIR}/browser-network-info.json
readonly HA_BROWSER_AUTH_CHECK=/usr/local/share/codex-ha/browser-auth-check.mjs
readonly NODE_BINARY=/usr/bin/node

rm -rf -- /run/codex-ha/playwright-output
install -d -m 0700 \
  "${RUNTIME_DIR}" \
  "${DATA_HOME}" \
  "${CODEX_DATA}" \
  "${SSH_DATA}" \
  "${TMUX_DATA}" \
  "${PLAYWRIGHT_OUTPUT}" \
  /root/.ssh
install -d -m 0755 /run/sshd

# shellcheck source=/dev/null
. /usr/local/lib/codex-ha/config.sh

if ! codex_ha_config_validate; then
  bashio::log.fatal '/data/options.json is missing or invalid'
  exit 1
fi

if [[ ! -d /config ]]; then
  bashio::log.fatal '/config is not mounted; map homeassistant_config to /config'
  exit 1
fi

if [[ ! -w /config ]]; then
  bashio::log.fatal '/config is not writable; read_only must be false'
  exit 1
fi

write_probe=$(mktemp /config/.codex-ha-write-test.XXXXXX)
rm -f "${write_probe}"
bashio::log.info 'Verified read-write access to /config'

approval_policy=$(codex_ha_config_string 'codex_approval_policy' 'on-request')
case "${approval_policy}" in
  untrusted | on-request | never) ;;
  *)
    bashio::log.fatal 'Invalid Codex approval policy'
    exit 1
    ;;
esac

sandbox_mode=$(codex_ha_config_string 'codex_sandbox_mode' 'danger-full-access')
case "${sandbox_mode}" in
  workspace-write | danger-full-access) ;;
  *)
    bashio::log.fatal 'Invalid Codex sandbox mode'
    exit 1
    ;;
esac

if [[ ! -e "${CODEX_DATA}/config.toml" ]]; then
  config_tmp=$(mktemp "${CODEX_DATA}/.config.toml.XXXXXX")
  {
    printf 'approval_policy = "%s"\n' "${approval_policy}"
    printf 'sandbox_mode = "%s"\n' "${sandbox_mode}"
    printf 'cli_auth_credentials_store = "file"\n'
    printf 'check_for_update_on_startup = false\n'
  } > "${config_tmp}"
  chmod 0600 "${config_tmp}"
  mv -f "${config_tmp}" "${CODEX_DATA}/config.toml"
  bashio::log.info 'Created persistent Codex configuration'
else
  chmod 0600 "${CODEX_DATA}/config.toml"
  bashio::log.info 'Preserved existing Codex configuration'
fi

if [[ ! -e "${CODEX_AGENTS}" && ! -L "${CODEX_AGENTS}" \
  && ! -e "${CODEX_AGENTS_OVERRIDE}" && ! -L "${CODEX_AGENTS_OVERRIDE}" ]]; then
  agents_tmp=$(mktemp "${CODEX_DATA}/.AGENTS.md.XXXXXX")
  install -m 0644 "${DEFAULT_AGENTS}" "${agents_tmp}"
  mv -f "${agents_tmp}" "${CODEX_AGENTS}"
  bashio::log.info 'Created persistent Home Assistant operating guidance for Codex'
else
  bashio::log.info 'Preserved existing Codex operating guidance'
fi

if [[ -e "${CODEX_DATA}/auth.json" ]]; then
  chmod 0600 "${CODEX_DATA}/auth.json"
fi

runtime_tmp=$(mktemp "${RUNTIME_DIR}/.runtime.env.XXXXXX")
{
  printf 'export HOME=%q\n' "${DATA_HOME}"
  printf 'export CODEX_HOME=%q\n' "${CODEX_DATA}"
  printf 'export HA_URL=%q\n' 'http://supervisor/core/api'
  printf 'export SUPERVISOR_URL=%q\n' 'http://supervisor'
  if [[ -n "${SUPERVISOR_TOKEN:-}" ]]; then
    if [[ "${SUPERVISOR_TOKEN}" == *$'\n'* || "${SUPERVISOR_TOKEN}" == *$'\r'* ]]; then
      bashio::log.fatal 'Supervisor token contains an invalid line break'
      exit 1
    fi
    printf 'export SUPERVISOR_TOKEN=%q\n' "${SUPERVISOR_TOKEN}"
  fi
} > "${runtime_tmp}"
chmod 0600 "${runtime_tmp}"
mv -f "${runtime_tmp}" "${RUNTIME_DIR}/runtime.env"

ssh_environment_tmp=$(mktemp /root/.ssh/.environment.XXXXXX)
{
  printf 'BASH_ENV=%s\n' '/etc/profile.d/codex-ha.sh'
  printf 'CODEX_HOME=%s\n' "${CODEX_DATA}"
  printf 'HA_URL=%s\n' 'http://supervisor/core/api'
  printf 'SUPERVISOR_URL=%s\n' 'http://supervisor'
  if [[ -n "${SUPERVISOR_TOKEN:-}" ]]; then
    printf 'SUPERVISOR_TOKEN=%s\n' "${SUPERVISOR_TOKEN}"
  fi
} > "${ssh_environment_tmp}"
chmod 0600 "${ssh_environment_tmp}"
mv -f "${ssh_environment_tmp}" /root/.ssh/environment

if [[ -z "${SUPERVISOR_TOKEN:-}" ]]; then
  bashio::log.warning 'SUPERVISOR_TOKEN is unavailable; API helpers will remain disabled'
else
  bashio::log.info 'Core and Supervisor API runtime environment configured'
fi

unset NODE_OPTIONS NODE_PATH
for variable in "${!PLAYWRIGHT_MCP_@}"; do
  unset "${variable}"
done
rm -f "${LEGACY_PLAYWRIGHT_SECRETS}" "${HA_BROWSER_TOKEN_FILE}" "${HA_BROWSER_AUTH_STATUS}"
browser_token=$(codex_ha_config_string 'home_assistant_browser_token' '')
auth_status_tmp=$(mktemp "${RUNTIME_DIR}/.browser-auth-status.XXXXXX")
if [[ -z "${browser_token}" ]]; then
  jq --null-input '{status: "unconfigured"}' > "${auth_status_tmp}"
  bashio::log.warning 'Dedicated read-only Home Assistant browser token is not configured; dashboard auto-login is disabled'
elif [[ ! "${browser_token}" =~ ^[A-Za-z0-9._~-]{20,}$ ]]; then
  jq --null-input '{status: "rejected", reason: "invalid_token_format"}' > "${auth_status_tmp}"
  bashio::log.warning 'Dedicated Home Assistant browser token has an invalid format; dashboard auto-login is disabled'
elif [[ -z "${SUPERVISOR_TOKEN:-}" ]]; then
  jq --null-input '{status: "rejected", reason: "supervisor_validation_unavailable"}' > "${auth_status_tmp}"
  bashio::log.warning 'Dedicated Home Assistant browser user cannot be verified without the Supervisor credential; dashboard auto-login is disabled'
elif HA_BROWSER_TOKEN="${browser_token}" "${NODE_BINARY}" "${HA_BROWSER_AUTH_CHECK}" \
  > "${auth_status_tmp}" 2>/dev/null; then
  browser_token_tmp=$(mktemp "${RUNTIME_DIR}/.home-assistant-browser-token.XXXXXX")
  printf '%s' "${browser_token}" > "${browser_token_tmp}"
  chmod 0600 "${browser_token_tmp}"
  mv -f "${browser_token_tmp}" "${HA_BROWSER_TOKEN_FILE}"

  bashio::log.info 'Validated the dedicated local-only, read-only Home Assistant browser user'
else
  jq --null-input '{status: "rejected", reason: "user_or_token_validation_failed"}' > "${auth_status_tmp}"
  bashio::log.warning 'Dedicated Home Assistant browser token or user policy validation failed; dashboard auto-login is disabled'
fi
chmod 0600 "${auth_status_tmp}"
mv -f "${auth_status_tmp}" "${HA_BROWSER_AUTH_STATUS}"
unset browser_token

ha_frontend_scheme=http
ha_frontend_port=8123
if [[ -n "${SUPERVISOR_TOKEN:-}" ]]; then
  core_info_tmp=$(mktemp "${RUNTIME_DIR}/.core-info.XXXXXX")
  if curl --fail --silent \
    --connect-timeout 1 \
    --max-time 2 \
    --header "Authorization: Bearer ${SUPERVISOR_TOKEN}" \
    --output "${core_info_tmp}" \
    http://supervisor/core/info; then
    candidate_port=$(jq --exit-status --raw-output \
      'select(.result == "ok") | .data.port // 8123 | tostring' \
      "${core_info_tmp}" 2>/dev/null || true)
    candidate_scheme=$(jq --exit-status --raw-output \
      'select(.result == "ok") | if (.data.ssl // false) then "https" else "http" end' \
      "${core_info_tmp}" 2>/dev/null || true)
    if [[ "${candidate_port}" =~ ^[0-9]+$ ]] \
      && (( candidate_port >= 1 && candidate_port <= 65535 )) \
      && [[ "${candidate_scheme}" == http || "${candidate_scheme}" == https ]]; then
      ha_frontend_port=${candidate_port}
      ha_frontend_scheme=${candidate_scheme}
    else
      bashio::log.warning 'Supervisor Core info did not contain a valid frontend endpoint; using the internal default'
    fi
  else
    bashio::log.warning 'Supervisor Core info is unavailable; using the internal Home Assistant frontend default'
  fi
  rm -f "${core_info_tmp}"
fi

ha_render_upstream_tmp=$(mktemp "${RUNTIME_DIR}/.home-assistant-render-upstream.XXXXXX")
printf 'set %s "%s://homeassistant:%s";\n' \
  "\$ha_frontend_upstream" "${ha_frontend_scheme}" "${ha_frontend_port}" \
  > "${ha_render_upstream_tmp}"
chmod 0600 "${ha_render_upstream_tmp}"
mv -f "${ha_render_upstream_tmp}" "${HA_RENDER_UPSTREAM}"
bashio::log.info 'Configured the loopback Home Assistant browser gateway'

browser_network_tmp=$(mktemp "${RUNTIME_DIR}/.browser-network-info.XXXXXX")
if /usr/local/bin/ha-browser-network-info > "${browser_network_tmp}" 2>/dev/null; then
  chmod 0600 "${browser_network_tmp}"
  mv -f "${browser_network_tmp}" "${HA_BROWSER_NETWORK_STATUS}"
  browser_source_ip=$(jq --raw-output '.socket_source_ip' "${HA_BROWSER_NETWORK_STATUS}")
  bashio::log.info "Home Assistant browser traffic uses current App address ${browser_source_ip}; this dynamic address is not trusted_networks identity"
else
  rm -f "${browser_network_tmp}" "${HA_BROWSER_NETWORK_STATUS}"
  bashio::log.warning 'Home Assistant browser request source address is not available yet; run ha-browser-network-info after Core is ready'
fi

for key_type in ed25519 rsa; do
  host_key="${SSH_DATA}/ssh_host_${key_type}_key"
  if [[ ! -s "${host_key}" ]]; then
    rm -f "${host_key}" "${host_key}.pub"
    if [[ "${key_type}" == rsa ]]; then
      ssh-keygen -q -t rsa -b 3072 -N '' -f "${host_key}"
    else
      ssh-keygen -q -t ed25519 -N '' -f "${host_key}"
    fi
    bashio::log.info "Generated persistent SSH ${key_type} host key"
  fi
  chmod 0600 "${host_key}"
  host_key_pub_tmp=$(mktemp "${SSH_DATA}/.ssh_host_${key_type}.pub.XXXXXX")
  if ! ssh-keygen -y -f "${host_key}" > "${host_key_pub_tmp}"; then
    rm -f "${host_key_pub_tmp}"
    bashio::log.fatal "Persistent SSH ${key_type} host key is invalid; refusing to replace its identity"
    exit 1
  fi
  chmod 0644 "${host_key_pub_tmp}"
  if [[ ! -s "${host_key}.pub" ]] || ! cmp -s "${host_key_pub_tmp}" "${host_key}.pub"; then
    mv -f "${host_key_pub_tmp}" "${host_key}.pub"
  else
    rm -f "${host_key_pub_tmp}"
  fi
  chmod 0644 "${host_key}.pub"
done

authorized_keys_json=$(codex_ha_config_json 'authorized_keys' '[]')
if ! jq --exit-status 'type == "array"' <<< "${authorized_keys_json}" >/dev/null; then
  bashio::log.fatal 'authorized_keys must be a list'
  exit 1
fi

authorized_keys_tmp=$(mktemp "${SSH_DATA}/.authorized_keys.XXXXXX")
key_probe=$(mktemp "${SSH_DATA}/.key-probe.XXXXXX")
valid_key_count=0
invalid_key_count=0
while IFS= read -r encoded_key; do
  public_key=$(printf '%s' "${encoded_key}" | base64 --decode)
  if [[ -z "${public_key}" ]]; then
    continue
  fi
  if [[ "${public_key}" == *$'\n'* || "${public_key}" == *$'\r'* ]]; then
    invalid_key_count=$((invalid_key_count + 1))
    continue
  fi
  if [[ ! "${public_key}" =~ ^(ssh-(ed25519|rsa)|ecdsa-sha2-nistp(256|384|521)|sk-ssh-ed25519@openssh\.com|sk-ecdsa-sha2-nistp256@openssh\.com)[[:space:]]+[A-Za-z0-9+/=]+([[:space:]].*)?$ ]]; then
    invalid_key_count=$((invalid_key_count + 1))
    continue
  fi
  printf '%s\n' "${public_key}" > "${key_probe}"
  if ! ssh-keygen -l -f "${key_probe}" >/dev/null 2>&1; then
    invalid_key_count=$((invalid_key_count + 1))
    continue
  fi
  printf '%s\n' "${public_key}" >> "${authorized_keys_tmp}"
  valid_key_count=$((valid_key_count + 1))
done < <(jq --raw-output '.[] | @base64' <<< "${authorized_keys_json}")
rm -f "${key_probe}"

chmod 0600 "${authorized_keys_tmp}"
mv -f "${authorized_keys_tmp}" "${SSH_DATA}/authorized_keys"

if (( invalid_key_count > 0 )); then
  bashio::log.warning "Ignored ${invalid_key_count} invalid SSH public key(s)"
fi

if (( valid_key_count == 0 )); then
  : > "${RUNTIME_DIR}/ssh-disabled"
  chmod 0600 "${RUNTIME_DIR}/ssh-disabled"
  bashio::log.warning 'No valid authorized_keys configured; SSH is disabled while the web terminal remains available'
else
  rm -f "${RUNTIME_DIR}/ssh-disabled"
  bashio::log.info "Enabled public-key SSH with ${valid_key_count} authorized key(s)"
fi

# OpenSSH rejects public keys for a locked account. Password authentication stays disabled in sshd_config.
passwd -d root >/dev/null
usermod -s /bin/bash root

find "${TMUX_DATA}" -mindepth 1 -maxdepth 1 -type d -name 'tmux-*' -exec rm -rf -- {} +

sshd -t -f /etc/ssh/sshd_config
nginx -t -c /etc/nginx/nginx.conf

bashio::log.info "Codex runtime ready: $(codex --version)"
