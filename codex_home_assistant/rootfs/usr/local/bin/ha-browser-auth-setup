#!/usr/bin/env bash
set -Eeuo pipefail

umask 077

readonly HELPER=/usr/local/share/codex-ha/browser-user-admin.mjs
readonly RUNTIME_ENV=/run/codex-ha/runtime.env
readonly MANAGED_AUTH_DIRECTORY=/data/browser-auth
readonly MANAGED_LOCK=${MANAGED_AUTH_DIRECTORY}/operation.lock

if (( $# != 0 )); then
  echo 'Usage: ha-browser-auth-setup' >&2
  exit 2
fi

unset \
  BASH_ENV \
  ENV \
  HA_BROWSER_EXPECTED_CLIENT_NAME \
  HA_BROWSER_EXPECTED_DISPLAY_NAME \
  HA_BROWSER_EXPECTED_USER_ID \
  HA_BROWSER_TOKEN \
  NODE_OPTIONS \
  NODE_PATH
if [[ -z "${SUPERVISOR_TOKEN:-}" && -r "${RUNTIME_ENV}" ]]; then
  # shellcheck source=/dev/null
  . "${RUNTIME_ENV}"
fi
if [[ -z "${SUPERVISOR_TOKEN:-}" ]]; then
  echo 'SUPERVISOR_TOKEN is unavailable; managed browser authentication cannot be configured' >&2
  exit 1
fi

# shellcheck source=/dev/null
. /usr/local/lib/codex-ha/config.sh
if ! codex_ha_config_validate; then
  echo 'App options are unavailable or invalid' >&2
  exit 1
fi
manual_token=$(codex_ha_config_string home_assistant_browser_token '')
if [[ -n "${manual_token}" ]]; then
  unset manual_token
  echo 'The manual home_assistant_browser_token option is active; clear it before enabling managed authentication' >&2
  exit 1
fi
unset manual_token

if [[ -L "${MANAGED_AUTH_DIRECTORY}" ]]; then
  echo 'Managed browser authentication storage is unsafe' >&2
  exit 1
fi
install -d -m 0700 "${MANAGED_AUTH_DIRECTORY}"
if [[ ! -d "${MANAGED_AUTH_DIRECTORY}" \
  || $(stat -c '%u' "${MANAGED_AUTH_DIRECTORY}") != "$(id -u)" ]]; then
  echo 'Managed browser authentication storage is unsafe' >&2
  exit 1
fi
if [[ -L "${MANAGED_LOCK}" \
  || ( -e "${MANAGED_LOCK}" && ! -f "${MANAGED_LOCK}" ) ]]; then
  echo 'Managed browser authentication lock is unsafe' >&2
  exit 1
fi
exec 9>> "${MANAGED_LOCK}"
chmod 0600 "${MANAGED_LOCK}"
if ! flock -n 9; then
  echo 'Another managed browser authentication operation is running' >&2
  exit 1
fi

if result=$(node "${HELPER}" auto-setup); then
  :
else
  setup_rc=$?
  /usr/local/bin/ha-browser-auth-refresh --quiet || true
  exit "${setup_rc}"
fi
if ! /usr/local/bin/ha-browser-auth-refresh --quiet; then
  echo 'Managed authentication was created, but runtime activation failed; rerun ha-browser-auth-setup after checking Home Assistant' >&2
  exit 1
fi

user_id=$(jq --exit-status --raw-output '.user.id' <<< "${result}")
display_name=$(jq --exit-status --raw-output '.user.name' <<< "${result}")
reused=$(jq --raw-output '.reused' <<< "${result}")
if [[ "${reused}" != true && "${reused}" != false ]]; then
  echo 'Managed authentication returned an invalid reuse status' >&2
  exit 1
fi
printf 'Managed browser authentication is ready.\n'
printf 'User ID: %s\n' "${user_id}"
printf 'Display name: %s\n' "${display_name}"
printf 'Reused existing setup: %s\n' "${reused}"
printf 'The temporary password and login refresh token were removed automatically.\n'
/usr/local/bin/ha-browser-auth-status
