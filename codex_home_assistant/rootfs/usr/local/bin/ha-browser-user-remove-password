#!/usr/bin/env bash
set -Eeuo pipefail

readonly HELPER=/usr/local/share/codex-ha/browser-user-admin.mjs

if (( $# != 1 )); then
  echo 'Usage: ha-browser-user-remove-password <user-id>' >&2
  exit 2
fi

result=$(node "${HELPER}" remove-password "$1")
user_id=$(jq --exit-status --raw-output '.user.id' <<< "${result}")
display_name=$(jq --exit-status --raw-output '.user.name' <<< "${result}")
username=$(jq --exit-status --raw-output '.user.username' <<< "${result}")

printf 'User ID: %s\n' "${user_id}"
printf 'Display name: %s\n' "${display_name}"
printf 'Username removed: %s\n' "${username}"
printf 'Next steps:\n'
printf '  1. Run ha-browser-auth-status and confirm it remains ready.\n'
printf '  2. Open http://127.0.0.1:8099 with the bundled Playwright browser.\n'
